APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
IMAGE_PUBLIC_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ALLOWED_REFERER_DOMAINS=localhost,127.0.0.1,yuexiang.com
BLOCKED_REFERER_DOMAINS=
ALLOW_EMPTY_REFERER=true
ADMIN_TOKEN=dev-admin-token
JWT_SECRET=dev-change-me
IMAGE_SIGNING_SECRET=dev-image-signing-secret
MODERATION_BLOCKED_HASHES=

DATABASE_URL=postgres://postgres:postgres@localhost:5432/yuexiang_image?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_DB=0
QUEUE_DRIVER=redis
QUEUE_STREAM=yuexiang:image:tasks
QUEUE_DEAD_LETTER_STREAM=yuexiang:image:tasks:dead
QUEUE_GROUP=yuexiang-image-workers
WORKER_NAME=worker-local
WORKER_BATCH_SIZE=5
WORKER_POLL_INTERVAL=5s
WORKER_RETRY_LIMIT=5
WORKER_CLAIM_IDLE=2m

S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=yuexiang-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
STORAGE_DRIVER=s3

IFPAY_BASE_URL=http://localhost:8081
IFPAY_PARTNER_APP_ID=yuexiang-image
IFPAY_CLIENT_ID=
IFPAY_CLIENT_SECRET=
IFPAY_PRIVATE_KEY_PEM=
IFPAY_PUBLIC_KEY_PEM=
IFPAY_WEBHOOK_PUBLIC_KEY_PEM=
IFPAY_REDIRECT_URI=http://localhost:5173/oauth/ifpay/callback

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=悦享图床 <noreply@yuexiang.local>
