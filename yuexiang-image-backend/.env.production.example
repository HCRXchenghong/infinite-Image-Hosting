APP_ENV=production
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://api.yourdomain.com
IMAGE_PUBLIC_BASE_URL=https://img.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_REFERER_DOMAINS=yourdomain.com,app.yourdomain.com
BLOCKED_REFERER_DOMAINS=
ALLOW_EMPTY_REFERER=false

ADMIN_TOKEN=REPLACE_WITH_32_PLUS_RANDOM_CHARS
JWT_SECRET=REPLACE_WITH_48_PLUS_RANDOM_CHARS
IMAGE_SIGNING_SECRET=REPLACE_WITH_48_PLUS_RANDOM_CHARS
MODERATION_BLOCKED_HASHES=ahash:REPLACE_WITH_BLOCKED_PHASH

DATABASE_URL=postgres://yuexiang:REPLACE_WITH_DB_PASSWORD@postgres:5432/yuexiang_image?sslmode=require
REDIS_ADDR=redis:6379
REDIS_DB=0
QUEUE_DRIVER=redis
QUEUE_STREAM=yuexiang:image:tasks
QUEUE_DEAD_LETTER_STREAM=yuexiang:image:tasks:dead
QUEUE_GROUP=yuexiang-image-workers
WORKER_NAME=worker-prod-1
WORKER_BATCH_SIZE=5
WORKER_POLL_INTERVAL=5s
WORKER_RETRY_LIMIT=5
WORKER_CLAIM_IDLE=2m

S3_ENDPOINT=https://s3.your-provider.example
S3_REGION=auto
S3_BUCKET=yuexiang-images-prod
S3_ACCESS_KEY=REPLACE_WITH_OBJECT_STORAGE_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_OBJECT_STORAGE_SECRET_KEY
S3_FORCE_PATH_STYLE=false
STORAGE_DRIVER=s3

IFPAY_BASE_URL=https://api.ifpay.example
IFPAY_PARTNER_APP_ID=yuexiang-image
IFPAY_CLIENT_ID=REPLACE_WITH_IFPAY_CLIENT_ID
IFPAY_CLIENT_SECRET=REPLACE_WITH_IFPAY_CLIENT_SECRET
IFPAY_PRIVATE_KEY_PEM=REPLACE_WITH_SINGLE_LINE_OR_ESCAPED_PRIVATE_KEY_PEM
IFPAY_PUBLIC_KEY_PEM=REPLACE_WITH_IFPAY_PUBLIC_KEY_PEM
IFPAY_WEBHOOK_PUBLIC_KEY_PEM=REPLACE_WITH_IFPAY_WEBHOOK_PUBLIC_KEY_PEM
IFPAY_REDIRECT_URI=https://app.yourdomain.com/oauth/ifpay/callback

SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=Yuexiang Image <no-reply@yourdomain.com>
